{
  "openapi": "3.1.0",
  "info": {
    "title": "backend-website",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "General"
        ],
        "operationId": "handler",
        "responses": {
          "200": {
            "description": "Health check successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "ok",
                  "version": "0.1.0"
                }
              }
            }
          }
        }
      }
    },
    "/hello": {
      "get": {
        "tags": [
          "General"
        ],
        "operationId": "handler",
        "responses": {
          "200": {
            "description": "Simple Hello Response!",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                },
                "example": {
                  "message": "Hello from Financiar backend!",
                  "status": "ok",
                  "version": "0.1.0"
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "operationId": "handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User logged in successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUserResponse"
                },
                "example": {
                  "code": 200,
                  "message": "Login successful",
                  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUserResponse"
                },
                "example": {
                  "code": 400,
                  "message": "Email and password are required"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUserResponse"
                },
                "example": {
                  "code": 401,
                  "message": "Invalid email or password"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUserResponse"
                },
                "example": {
                  "code": 500,
                  "message": "An unexpected error occurred. Please try again later."
                }
              }
            }
          }
        }
      }
    },
    "/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "operationId": "handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                },
                "example": {
                  "code": 200,
                  "message": "User registered successfully"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                },
                "examples": {
                  "Invalid Email": {
                    "summary": "Triggered when the email is invalid (either wrong format or not provided)",
                    "value": {
                      "code": 400,
                      "message": "Invalid e-mail"
                    }
                  },
                  "Invalid Risk Profile": {
                    "summary": "Triggered when risk profile is not a permitted value",
                    "value": {
                      "code": 400,
                      "message": "Invalid risk profile. Must be 'conservative', 'moderate', or 'aggressive'."
                    }
                  },
                  "Weak Password": {
                    "summary": "Triggered when password requirements are not met",
                    "value": {
                      "code": 400,
                      "message": "Password must be at least 8 characters long and contain a mix of letters, numbers, and special characters"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "User already exists for that email",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                },
                "example": {
                  "code": 409,
                  "message": "User already exists for that email!"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                },
                "example": {
                  "code": 500,
                  "message": "An unexpected error occurred. Please try again later."
                }
              }
            }
          }
        }
      }
    },
    "/shares": {
      "get": {
        "tags": [
          "Share"
        ],
        "operationId": "handler",
        "responses": {
          "200": {
            "description": "List of shares declared by the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListSharesResponse"
                },
                "example": {
                  "shares": [
                    {
                      "created_at": "2026-05-28T12:00:00Z",
                      "id": 1,
                      "quantity": 10,
                      "ticker": "GGAL",
                      "user_id": 42
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      },
      "post": {
        "tags": [
          "Share"
        ],
        "operationId": "handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShareRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Share added to the authenticated user's portfolio",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateShareResponse"
                },
                "example": {
                  "created_at": "2026-05-28T12:00:00Z",
                  "id": 1,
                  "quantity": 10,
                  "ticker": "GGAL",
                  "user_id": 42
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "409": {
            "description": "The authenticated user already has this ticker in their portfolio"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/shares/all": {
      "get": {
        "tags": [
          "Share"
        ],
        "operationId": "handler",
        "responses": {
          "200": {
            "description": "List of all available share tickers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAllSharesResponse"
                },
                "example": {
                  "shares": [
                    {
                      "id": 1,
                      "ticker": "GGAL"
                    },
                    {
                      "id": 2,
                      "ticker": "YPF"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/shares/{id}": {
      "put": {
        "tags": [
          "Share"
        ],
        "operationId": "handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of the share to update",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateShareRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Share updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateShareResponse"
                },
                "example": {
                  "created_at": "2026-05-28T12:00:00Z",
                  "id": 1,
                  "quantity": 25,
                  "ticker": "GGAL",
                  "user_id": 42
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "404": {
            "description": "Share not found for the authenticated user"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Share"
        ],
        "operationId": "handler",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of the share to delete",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Share deleted successfully"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "404": {
            "description": "Share not found for the authenticated user"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/user": {
      "get": {
        "tags": [
          "User"
        ],
        "operationId": "handler",
        "responses": {
          "200": {
            "description": "Authenticated user retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetUserResponse"
                },
                "example": {
                  "created_at": "2026-05-13T12:00:00Z",
                  "email": "financiar186@gmail.com",
                  "full_name": "John Doe",
                  "id": 1,
                  "is_active": true,
                  "risk_profile": "moderate"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "404": {
            "description": "Authenticated user no longer exists"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CreateShareRequest": {
        "type": "object",
        "required": [
          "ticker",
          "quantity"
        ],
        "properties": {
          "quantity": {
            "type": "integer",
            "format": "int32",
            "example": 10
          },
          "ticker": {
            "type": "string",
            "example": "GGAL"
          }
        }
      },
      "CreateShareResponse": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "ticker",
          "quantity",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "ticker": {
            "type": "string"
          },
          "user_id": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "GetUserResponse": {
        "type": "object",
        "required": [
          "id",
          "email",
          "full_name",
          "is_active",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "email": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "is_active": {
            "type": "boolean"
          },
          "risk_profile": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "HelloResponse": {
        "type": "object",
        "required": [
          "status",
          "version",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "ListAllSharesResponse": {
        "type": "object",
        "required": [
          "shares"
        ],
        "properties": {
          "shares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShareTickerItem"
            }
          }
        }
      },
      "ListSharesResponse": {
        "type": "object",
        "required": [
          "shares"
        ],
        "properties": {
          "shares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShareItem"
            }
          }
        }
      },
      "LoginUserRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "financiar186@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPassword123!"
          }
        }
      },
      "LoginUserResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "message": {
            "type": "string"
          },
          "token": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "RegisterUserRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "full_name"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "financiar186@gmail.com"
          },
          "full_name": {
            "type": "string",
            "example": "John Doe"
          },
          "password": {
            "type": "string",
            "example": "StrongPassword123!"
          },
          "risk_profile": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional. Must be 'conservative', 'moderate', or 'aggressive'",
            "example": "moderate"
          }
        }
      },
      "RegisterUserResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ShareItem": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "ticker",
          "quantity",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "ticker": {
            "type": "string"
          },
          "user_id": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ShareTickerItem": {
        "type": "object",
        "required": [
          "id",
          "ticker"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "ticker": {
            "type": "string"
          }
        }
      },
      "UpdateShareRequest": {
        "type": "object",
        "required": [
          "quantity"
        ],
        "properties": {
          "quantity": {
            "type": "integer",
            "format": "int32",
            "example": 25
          }
        }
      },
      "UpdateShareResponse": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "ticker",
          "quantity",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "ticker": {
            "type": "string"
          },
          "user_id": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Endpoints for user identity management"
    },
    {
      "name": "User",
      "description": "Endpoints for retrieving authenticated user information"
    },
    {
      "name": "Share",
      "description": "Endpoints for managing the authenticated user's declared stock portfolio"
    },
    {
      "name": "General",
      "description": "General endpoints for knowing the status of the backend and other general information"
    }
  ]
}